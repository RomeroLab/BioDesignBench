# BioDesignBench Environment Variables
# Copy to .env and fill in your keys: cp .env.example .env

# === LLM API Keys (for general-purpose agents) ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...
DEEPSEEK_API_KEY=sk-...

# === Google Vertex AI (for Gemini agents) ===
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# === Bio-specific agent backends ===
# These agents use LLM backends for code generation
BIOMNI_MODEL=gpt-4o
STELLA_MODEL=gpt-4o
AIDE_MODEL=gpt-4o

# === Execution Settings ===
# Docker sandbox image name
SANDBOX_IMAGE=biodesignbench-sandbox
# Default timeout for code execution (seconds)
SANDBOX_TIMEOUT=300
# Memory limit for sandbox containers
SANDBOX_MEMORY_LIMIT=4g
